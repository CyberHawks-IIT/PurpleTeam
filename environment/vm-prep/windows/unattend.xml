<?xml version="1.0" encoding="utf-8"?>
<unattend xmlns="urn:schemas-microsoft-com:unattend">

  <!-- ════════════════════════════════════════════════════════
       PASS 4 – specialize
       Runs once on the target machine after image is applied.
       Re-enables WinRM + OpenSSH so Ansible can reach the host.
       ════════════════════════════════════════════════════════ -->
  <settings pass="specialize">
    <component name="Microsoft-Windows-Deployment"
               processorArchitecture="amd64"
               publicKeyToken="31bf3856ad364e35"
               language="neutral"
               versionScope="nonSxS"
               xmlns:wcm="http://schemas.microsoft.com/WMIConfig/2002/State">
      <RunSynchronous>
        <!-- Ensure WinRM starts and is configured for Ansible -->
        <RunSynchronousCommand wcm:action="add">
          <Order>1</Order>
          <Path>cmd /c sc config WinRM start=auto &amp;&amp; net start WinRM</Path>
          <Description>Start WinRM</Description>
        </RunSynchronousCommand>
        <RunSynchronousCommand wcm:action="add">
          <Order>2</Order>
          <Path>cmd /c winrm quickconfig -quiet</Path>
          <Description>WinRM quickconfig</Description>
        </RunSynchronousCommand>
        <RunSynchronousCommand wcm:action="add">
          <Order>3</Order>
          <Path>cmd /c winrm set winrm/config/service @{AllowUnencrypted="true"}</Path>
          <Description>WinRM allow unencrypted</Description>
        </RunSynchronousCommand>
        <RunSynchronousCommand wcm:action="add">
          <Order>4</Order>
          <Path>cmd /c winrm set winrm/config/service/auth @{Basic="true"}</Path>
          <Description>WinRM enable basic auth</Description>
        </RunSynchronousCommand>
        <RunSynchronousCommand wcm:action="add">
          <Order>5</Order>
          <Path>cmd /c sc config sshd start=auto &amp;&amp; net start sshd</Path>
          <Description>Start OpenSSH Server</Description>
        </RunSynchronousCommand>
        <RunSynchronousCommand wcm:action="add">
          <Order>6</Order>
          <Path>powershell -NoProfile -Command "Set-ExecutionPolicy RemoteSigned -Force -Scope LocalMachine"</Path>
          <Description>Set execution policy</Description>
        </RunSynchronousCommand>
        <!-- Enable automatic timezone detection. Falls back to the TimeZone
             value below if location services are unavailable (common in VMs). -->
        <RunSynchronousCommand wcm:action="add">
          <Order>7</Order>
          <Path>cmd /c sc config tzautoupdate start=auto &amp;&amp; net start tzautoupdate</Path>
          <Description>Enable automatic timezone update</Description>
        </RunSynchronousCommand>
      </RunSynchronous>
    </component>

    <component name="Microsoft-Windows-Shell-Setup"
               processorArchitecture="amd64"
               publicKeyToken="31bf3856ad364e35"
               language="neutral"
               versionScope="nonSxS">
      <ComputerName>*</ComputerName>
      <!-- Central Standard Time (Chicago) — tzautoupdate will override this
           automatically if Windows location services are available. -->
      <TimeZone>Central Standard Time</TimeZone>
    </component>
  </settings>

  <!-- ════════════════════════════════════════════════════════
       PASS 7 – oobeSystem
       Skips all OOBE screens and creates local admin account.
       ════════════════════════════════════════════════════════ -->
  <settings pass="oobeSystem">
    <component name="Microsoft-Windows-International-Core"
               processorArchitecture="amd64"
               publicKeyToken="31bf3856ad364e35"
               language="neutral"
               versionScope="nonSxS">
      <InputLocale>en-US</InputLocale>
      <SystemLocale>en-US</SystemLocale>
      <UILanguage>en-US</UILanguage>
      <UserLocale>en-US</UserLocale>
    </component>

    <component name="Microsoft-Windows-Shell-Setup"
               processorArchitecture="amd64"
               publicKeyToken="31bf3856ad364e35"
               language="neutral"
               versionScope="nonSxS">
      <OOBE>
        <HideEULAPage>true</HideEULAPage>
        <HideLocalAccountScreen>true</HideLocalAccountScreen>
        <HideOEMRegistrationScreen>true</HideOEMRegistrationScreen>
        <HideOnlineAccountScreens>true</HideOnlineAccountScreens>
        <HideWirelessSetupInOOBE>true</HideWirelessSetupInOOBE>
        <NetworkLocation>Work</NetworkLocation>
        <ProtectYourPC>3</ProtectYourPC>
        <SkipMachineOOBE>true</SkipMachineOOBE>
        <SkipUserOOBE>true</SkipUserOOBE>
      </OOBE>

      <!-- ── Local administrator account ── -->
      <UserAccounts>
        <LocalAccounts>
          <LocalAccount wcm:action="add">
            <Name>admin</Name>
            <Group>Administrators</Group>
            <Password>
              <!-- CHANGE THIS after first boot -->
              <Value>Password123!</Value>
              <PlainText>true</PlainText>
            </Password>
          </LocalAccount>
        </LocalAccounts>
      </UserAccounts>

      <AutoLogon>
        <Enabled>true</Enabled>
        <Username>admin</Username>
        <Password>
          <Value>Password123!</Value>
          <PlainText>true</PlainText>
        </Password>
        <LogonCount>1</LogonCount>
      </AutoLogon>

      <!-- Run on first logon — final Ansible readiness -->
      <FirstLogonCommands>
        <SynchronousCommand wcm:action="add">
          <Order>1</Order>
          <CommandLine>powershell -NoProfile -Command "Enable-PSRemoting -Force -SkipNetworkProfileCheck"</CommandLine>
          <Description>Enable PS Remoting</Description>
        </SynchronousCommand>
        <SynchronousCommand wcm:action="add">
          <Order>2</Order>
          <CommandLine>powershell -NoProfile -Command "Set-NetFirewallRule -Name 'WinRM-HTTP-In' -Enabled True -ErrorAction SilentlyContinue; New-NetFirewallRule -Name 'WinRM-HTTP-In' -DisplayName 'WinRM HTTP' -Direction Inbound -Protocol TCP -LocalPort 5985 -Action Allow -Profile Any -ErrorAction SilentlyContinue"</CommandLine>
          <Description>Ensure WinRM firewall rule</Description>
        </SynchronousCommand>
      </FirstLogonCommands>
    </component>
  </settings>

</unattend>
